{
  "name": "studylink-starter",
  "version": "1.4.0",
  "description": "StudyLink starter app with PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node --watch src/server.js",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node src/seed.js",
    "test:flows": "node --test tests/critical-flows.integration.test.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "security:scan:staged": "node scripts/security-scan.mjs --staged"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "vite": "^5.4.0"
  }
}

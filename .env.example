# Example environment variables for StudyLink
# Copy this file to `.env` and fill in real values. DO NOT commit your real `.env`.

# Application
PORT=3000
APP_HOST_PORT=3001
SESSION_DURATION_HOURS=24
STREAK_TIMEZONE=Asia/Kuala_Lumpur
ADMIN_EMAIL=admin@studylink.local
ADMIN_PASSWORD=changeme

# Database (recommended: use DATABASE_URL for hosted DBs)
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Or use individual settings for local DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=studylink
DB_PASSWORD=studylink
DB_NAME=studylink
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Deployment / runtime
NODE_ENV=development
SKIP_DB_INIT=false

# Set this in production so emailed links point to the live site.
# FRONTEND_ORIGIN=https://studylink.up.railway.app
